# =============================================================================
# IB Trading Agent Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required fields are marked with [REQUIRED].
# Optional fields show their default values.
# =============================================================================

# -----------------------------------------------------------------------------
# Interactive Brokers Connection [REQUIRED]
# -----------------------------------------------------------------------------
# Your IB account ID
IB_ACCOUNT_ID=

# TWS/Gateway host address (default: 127.0.0.1)
IB_HOST=127.0.0.1

# TWS/Gateway port (paper: 7497/4002, live: 7496/4001)
IB_PORT=7497

# Trading environment: "paper" or "live"
# Start with "paper" to test without risking real capital
ENVIRONMENT=paper

# -----------------------------------------------------------------------------
# Email Notifications
# -----------------------------------------------------------------------------
# Email address for daily reports and alerts
EMAIL_ADDRESS=

# SMTP server configuration
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

# -----------------------------------------------------------------------------
# Risk Management (defaults shown)
# -----------------------------------------------------------------------------
# Portfolio hard stop — halt trading when total loss exceeds this %
MAX_PORTFOLIO_LOSS_PCT=20

# Maximum portfolio allocation to any single stock (%)
MAX_POSITION_SIZE_PCT=25

# Per-position stop-loss percentage
STOP_LOSS_PCT=5

# Minimum cash reserve as % of portfolio value
CASH_BUFFER_PCT=10

# -----------------------------------------------------------------------------
# LLM Configuration (defaults shown)
# -----------------------------------------------------------------------------
# Anthropic model for sentiment analysis and report generation
LLM_MODEL=claude-sonnet-4-6

# Maximum LLM API calls per calendar day (cost control)
MAX_LLM_CALLS_PER_DAY=10

# Anthropic API key [REQUIRED for LLM features]
ANTHROPIC_API_KEY=

# Database
# SQLite (local) or PostgreSQL (server) connection URL
DB_URL=sqlite:///data/agent.db

# -----------------------------------------------------------------------------
# Market Data
# -----------------------------------------------------------------------------
# 1 = real-time (requires paid subscription)
# 3 = delayed (~15 min lag, free)
# 4 = frozen delayed (free, always available)
MARKET_DATA_TYPE=4
